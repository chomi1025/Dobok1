generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  ci                String?            @unique
  id                Int               @id @default(autoincrement())
  email             String            @unique
  password          String
  name              String
  username          String            @unique
  role              String            @default("user")
  phone             String?           @unique
  birthDate         DateTime
  address           Json?
  createdAt         DateTime          @default(now())
  inquiries         Inquiry[]
  inquiryReplies    InquiryReply[]
  orders            Order[]
  productQnas       ProductQna[]
  productQnaReplies ProductQnaReply[]
  reviews           Review[]
  reviewReplies     ReviewReply[]
}

model Verification {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  code      String
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  parentId  Int?
  slug      String     @unique
  imageUrl  String?
  sortOrder Int?
  parent    Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToCategory")
  products  Product[]
}

model Product {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  thumbnail   String?
  images      String[]
  material    String          @default("")
  origin      String          @default("")
  createdAt   DateTime        @default(now())
  categoryId  Int
  cartItems   CartItem[]
  orderItems  OrderItem[]
  category    Category        @relation(fields: [categoryId], references: [id])
  options     ProductOption[]
  productQnas ProductQna[]
}

model ProductOption {
  id        Int        @id @default(autoincrement())
  color     String?
  size      String?
  price     Int
  stock     Int
  status    String     @default("판매중")
  sale      Int?
  productId Int
  cartItems CartItem[]
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model CartItem {
  id              Int           @id @default(autoincrement())
  userId          Int
  productId       Int
  productOptionId Int
  quantity        Int           @default(1)
  createdAt       DateTime      @default(now())
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  option          ProductOption @relation(fields: [productOptionId], references: [id])
}

model Order {
  id          Int         @id @default(autoincrement())
  orderNumber String      @unique
  createdAt   DateTime    @default(now())
  total       Int
  status      OrderStatus
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       OrderItem[]
}

model OrderItem {
  id           Int      @id @default(autoincrement())
  orderId      Int
  productId    Int
  productName  String
  productImage String?
  optionText   String?
  unitPrice    Int
  quantity     Int
  totalPrice   Int
  createdAt    DateTime @default(now())
  claims       Claim[]
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviews      Review?
}

model Claim {
  id          Int         @id @default(autoincrement())
  claimNumber String      @unique @default(uuid())
  claimType   ClaimType
  status      ClaimStatus @default(REQUESTED)
  requestedAt DateTime    @default(now())
  detail      String
  orderItemId Int?
  reason      String?
  processedAt DateTime?
  orderItem   OrderItem?  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model Review {
  id          Int          @id @default(autoincrement())
  orderItemId Int          @unique
  userId      Int
  rating      Int
  content     String
  createdAt   DateTime     @default(now())
  images      String[]     @default([])
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  reply       ReviewReply?
}

model ReviewReply {
  id        Int      @id @default(autoincrement())
  reviewId  Int      @unique
  adminId   Int
  content   String
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id])
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id        Int            @id @default(autoincrement())
  userId    Int
  content   String
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
  replies   InquiryReply[]
}

model InquiryReply {
  id        Int      @id @default(autoincrement())
  inquiryId Int
  adminId   Int
  content   String
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id])
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id])
}

model ProductQna {
  id        Int              @id @default(autoincrement())
  content   String
  isSecret  Boolean          @default(false)
  productId Int
  userId    Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply     ProductQnaReply?
}

model ProductQnaReply {
  id           Int        @id @default(autoincrement())
  content      String
  productQnaId Int        @unique
  adminId      Int
  createdAt    DateTime   @default(now())
  admin        User       @relation(fields: [adminId], references: [id])
  productQna   ProductQna @relation(fields: [productQnaId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PAYMENT_COMPLETE
  PREPARING
  SHIPPING
  DELIVERED
  CANCELLED
}

enum ClaimType {
  CANCEL
  RETURN
  EXCHANGE
}

enum ClaimStatus {
  REQUESTED
  APPROVED
  COMPLETED
  REJECTED
}
